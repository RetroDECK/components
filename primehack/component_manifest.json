{
  "primehack": {
    "name": "PrimeHack",
    "core_framework_compatibility": "1",
    "component_version": "1.0.0",
    "capabilities": ["reset","open"],
    "description": "PrimeHack is a modified fork of Dolphin for playing Metroid Prime with modern controls.",
    "url_rdwiki": "https://retrodeck.readthedocs.io/en/latest/wiki_emulator_guides/dolphin-primehack/dolphin-primehack-guide/",
    "url_webpage": "https://github.com/shiiion/dolphin/wiki/",
    "url_donation_purchase": "",
    "url_source": "https://github.com/shiiion/dolphin",
    "component_type": "Emulator",
    "system": [
      "gc",
      "wii"
    ],
    "system_friendly_name": [
      "GameCube",
      "Wii"
    ],
    "backup_data": {
      "core": [
        {"path": "$XDG_CONFIG_HOME/primehack"},
        {"path": "$XDG_DATA_HOME/primehack"}
      ]
    },
    "es_de_config": {
      "es_find_rules": {
        "emulators": [
          {
            "name": "PRIMEHACK",
            "description": "PrimeHack, fork of Nintendo GameCube and Wii emulator Dolphin",
            "rules": [
              {
                "type": "staticpath",
                "entries": [
                  "%COMPONENT_PATH%/component_launcher.sh"
                ]
              }
            ]
          }
        ]
      },
      "es_systems": [
        {
          "name": "gc",
          "fullname": "Nintendo GameCube",
          "path": "%ROMPATH%/gc",
          "extension": ".7z .ciso .dff .dol .elf .gcm .gcz .iso .json .m3u .rvz .tgc .wad .wbfs .wia .zip",
          "commands": [
            {
              "label": "PrimeHack (Standalone)",
              "command": "env QT_QPA_PLATFORM=xcb %EMULATOR_PRIMEHACK% -b -e %ROM%",
              "priority": 30
            }
          ],
          "platform": "gc",
          "theme": "gc"
        },
        {
          "name": "primehack",
          "fullname": "PrimeHack",
          "path": "%ROMPATH%/primehack",
          "extension": ".7z .ciso .dff .dol .elf .gcm .gcz .iso .json .m3u .rvz .tgc .wad .wbfs .wia .zip",
          "commands": [
            {
              "label": "PrimeHack (Standalone)",
              "command": "env QT_QPA_PLATFORM=xcb %EMULATOR_PRIMEHACK% -b -e %ROM%",
              "priority": 10
            }
          ],
          "platform": "wii",
          "theme": "primehack"
        },
        {
          "name": "wii",
          "fullname": "Nintendo Wii",
          "path": "%ROMPATH%/wii",
          "extension": ".7z .ciso .dff .dol .elf .gcm .gcz .iso .json .m3u .rvz .tgc .wad .wbfs .wia .zip",
          "commands": [
            {
              "label": "PrimeHack (Standalone)",
              "command": "env QT_QPA_PLATFORM=xcb %EMULATOR_PRIMEHACK% -b -e %ROM%",
              "priority": 30
            }
          ],
          "platform": "wii",
          "theme": "wii"
        }
      ]
    },
    "compatible_presets": {
      "ask_to_exit": ["false", "true"],
      "universal_dyn_input": ["false", "true"]
    },
    "preset_actions": {
      "config_file_format": "dolphin",
      "ask_to_exit": [
        {
          "enabled_states": ["true"],
          "setting_name": "ConfirmStop",
          "action": "change",
          "new_setting_value": "True",
          "section": "Interface",
          "target_file": "$primehack_config",
          "defaults_file": "$primehack_rd_config_dir/config/Dolphin.ini"
        }
      ],
      "universal_dyn_input": [
        {
          "enabled_states": ["true"],
          "setting_name": "Universal Dynamic Input",
          "action": "install",
          "source": "/app/retrodeck/components/shared-data/DynamicInputTextures/",
          "destination": "$primehack_dynamic_input_textures_path/",
          "cleanup_type": "purge"
        }
      ]
    }
  }
}
