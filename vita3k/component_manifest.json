{
  "vita3k": {
    "name": "Vita3K",
    "core_framework_compatibility": "1",
    "component_version": "1.0.0",
    "description": "Vita3K is a PlayStation Vita (psvita) emulator.",
    "url_rdwiki": "https://retrodeck.readthedocs.io/en/latest/wiki_emulator_guides/vita3k/vita3k-guide/",
    "url_webpage": "https://vita3k.org/",
    "url_donation_purchase": "https://ko-fi.com/vita3k/tiers",
    "url_source": "https://github.com/Vita3K/Vita3K",
    "component_type": "Emulator",
    "system_friendly_name": "PlayStation Vita",
    "system": "psvita",
    "es_de_config": {
      "es_find_rules": {
        "emulators": [
          {
            "name": "VITA3K",
            "description": "Sony PlayStation Vita emulator Vita3K",
            "rules": [
              {
                "type": "staticpath",
                "entries": [
                  "%COMPONENT_PATH%/component_launcher.sh"
                ]
              }
            ]
          }
        ]
      },
      "es_systems": [
        {
          "name": "psvita",
          "fullname": "Sony PlayStation Vita",
          "path": "%ROMPATH%/psvita",
          "extension": ".psvita",
          "commands": [
            {
              "label": "Vita3K (Standalone)",
              "command": "%EMULATOR_VITA3K% -r %INJECT%=%BASENAME%.psvita",
              "priority": 10
            }
          ],
          "platform": "psvita",
          "theme": "psvita"
        }
      ]
    },
    "helper_files": [
      {
        "filename": "vita3k_guide.txt",
        "location": "$roms_path/psvita"
      }
    ],
    "configurator_menus": {
      "tools": [
        {
          "name": "Install: Vita3K Firmware",
          "description": "Download and install: PlayStation Vita firmware for the Vita3K emulator.",
          "command": {
            "zenity": "update_vita3k_firmware"
          }
        }
      ]
    },
    "finit_options": [
      {
        "dialog": "finit_install_vita3k_firmware_dialog",
        "action": "update_vita3k_firmware"
      }
    ]
  }
}
