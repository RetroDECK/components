{
  "rpcs3": {
    "name": "RPCS3",
    "core_framework_compatibility": "1",
    "component_version": "1.0.0",
    "capabilities": ["reset","open"],
    "url_rdwiki": "https://retrodeck.readthedocs.io/en/latest/wiki_emulator_guides/rpcs3/rpcs3-guide/",
    "url_webpage": "https://rpcs3.net/",
    "url_donation_purchase": [
      "https://patreon.com/Nekotekina",
      "https://rpcs3.net/alipay"
    ],
    "url_source": "https://github.com/RPCS3/rpcs3",
    "description": "RPCS3 is a Playstation 3 (ps3) emulator.",
    "system_friendly_name": "PlayStation 3",
    "component_type": "Emulator",
    "system": "ps3",
    "backup_data": {
      "core": [
        {"path": "$XDG_CONFIG_HOME/rpcs3"}
      ]
    },
    "es_de_config": {
      "es_find_rules": {
        "emulators": [
          {
            "name": "RPCS3",
            "description": "Sony PlayStation 3 emulator RPCS3",
            "rules": [
              {
                "type": "staticpath",
                "entries": [
                  "%COMPONENT_PATH%/component_launcher.sh"
                ]
              }
            ]
          }
        ]
      },
      "es_systems": [
        {
          "name": "consolearcade",
          "fullname": "Console Arcade Systems",
          "path": "%ROMPATH%/consolearcade",
          "extension": ".7z .arcadedef .desktop .iso .ps3 .sh .xbe .zip",
          "commands": [
            {
              "label": "RPCS3 Game Serial (Standalone)",
              "command": "%EMULATOR_RPCS3% --di-gui %RPCS3_GAMEID%:%INJECT%=%BASENAME%.ps3",
              "priority": 60
            }
          ],
          "platform": "arcade",
          "theme": "consolearcade"
        },
        {
          "name": "ps3",
          "fullname": "Sony PlayStation 3",
          "path": "%ROMPATH%/ps3",
          "extension": ".desktop .ps3 .ps3dir",
          "commands": [
            {
              "label": "RPCS3 Game Serial (Standalone)",
              "command": "%EMULATOR_RPCS3% --no-gui %RPCS3_GAMEID%:%INJECT%=%BASENAME%.ps3",
              "priority": 20
            },
            {
              "label": "RPCS3 Directory (Standalone)",
              "command": "%EMULATOR_RPCS3% --no-gui %ROM%",
              "priority": 30
            }
          ],
          "platform": "ps3",
          "theme": "ps3"
        }
      ]
    },
    "helper_files": [
      {
        "filename": "rpcs3_guide.txt",
        "location": "$roms_path/ps3"
      }
    ],
    "configurator_menus": {
      "tools": [
        {
          "name": "Install: RPCS3 Firmware",
          "description": "Download and install: Playstation 3 firmware for the RPCS3 emulator.",
          "command": {
            "zenity": "update_rpcs3_firmware"
          }
        }
      ]
    },
    "finit_options": [
      {
        "dialog": "finit_install_rpcs3_firmware_dialog",
        "action": "update_rpcs3_firmware"
      }
    ]
  }
}
