{
  "retrodeck-api": [
    {
      "source_url": "$REPO_ROOT/$COMPONENT_NAME",
      "source_type": "local",
      "extraction_type": "local",
      "version": "latest",
      "assets": [
        {
          "type": "file",
          "source": "component_functions.sh",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        },
        {
          "type": "file",
          "source": "component_manifest.json",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        },
        {
          "type": "file",
          "source": "component_recipe.json",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        },
        {
          "type": "dir",
          "source": "rd_assets/rd_tools",
          "dest": "rd_tools"
        }
      ]
    }
  ]
}
