{
  "retrodeck-api": [
    {
      "source_url": "$REPO_ROOT/$COMPONENT_NAME",
      "source_type": "local",
      "extraction_type": "local",
      "version": "latest",
      "assets": [
        {
          "type": "file",
          "source": "component_functions.sh",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        },
        {
          "type": "file",
          "source": "component_manifest.json",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        },
        {
          "type": "file",
          "source": "component_recipe.json",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        },
        {
          "type": "dir",
          "source": "rd_assets/rd_tools",
          "dest": "rd_tools"
        }
      ]
    },
    {
      "source_url": "http://www.dest-unreach.org/socat/download/socat-{VERSION}.tar.gz",
      "source_type": "http",
      "extraction_type": "archive",
      "version": "1.8.1.1",
      "assets": [
        {
          "type": "script",
          "source": "$REPO_ROOT/$COMPONENT_NAME/rd_assets/scripts/build_socat.sh"
        },
        {
          "type": "file",
          "source": "$EXTRACTED_PATH/socat-$SOURCE_VERSION/socat",
          "dest": "bin"
        }
      ]
    }
  ]
}
