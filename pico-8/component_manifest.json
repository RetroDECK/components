{
  "pico-8": {
    "name": "PICO-8",
    "core_framework_compatibility": "1",
    "component_version": "1.0.0",
    "url_rdwiki": "https://retrodeck.readthedocs.io/en/latest/wiki_emulator_guides/pico-8/pico-8-guide/",
    "url_webpage": "https://www.lexaloffle.com/pico-8.php",
    "url_donation_purchase": "",
    "description": "PICO-8 is a fantasy console for playing tiny, retro-style games.",
    "system_friendly_name": "PICO-8 Fantasy Console",
    "component_type": "Emulator",
    "system": "pico8",
    "component_options": {
      "splore_visible": "false"
    },
    "configurator_menus": {
      "settings": [
        {
          "name": "PICO-8 Splore Visibility",
          "description": "Enable or disable: PICO-8 Splore entry visibility.",
          "command": {
            "zenity": "configurator_splore_toggle_dialog"
          }
        }
      ]
    },
    "es_de_config": {
      "es_find_rules": {
        "emulators": [
          {
            "name": "PICO-8",
            "description": "PICO-8 Fantasy Console (game engine)",
            "rules": [
              {
                "type": "staticpath",
                "entries": [
                  "%COMPONENT_PATH%/component_launcher.sh"
                ]
              }
            ]
          }
        ]
      },
      "es_systems": [
        {
          "name": "pico8",
          "fullname": "PICO-8 Fantasy Console",
          "path": "%ROMPATH%/pico8",
          "extension": ".p8 .png",
          "commands": [
            {
              "label": "PICO-8 (Standalone)",
              "command": "%EMULATOR_PICO-8% -root_path %GAMEDIR% -run %ROM%",
              "priority": 10
            },
            {
              "label": "PICO-8 Splore (Standalone)",
              "command": "%EMULATOR_PICO-8% -root_path %GAMEDIR% -splore",
              "priority": 20
            }
          ],
          "platform": "pico8",
          "theme": "pico8"
        }
      ]
    },
    "es_de_gamelist_entries": {
      "image_root": "%COMPONENT_PATH%/rd_extras/es_de_media",
      "entries": {
        "pico8_splore": {
          "system": "pico8",
          "create_file": "$roms_path/pico8/splore.png",
          "gamelist_data": {
            "path": "splore.png",
            "name": "PICO-8 Splore",
            "desc": "Splore is a graphical interface for exploring PICO-8 cartridges. You can use Splore to browse, search, and play cartridges published to the forum (BBS) directly over the Internet. You can also use Splore to navigate the cartridge storage area, with or without an Internet connection.",
            "releasedate": "20150401T000000",
            "developer": "Lexaloffle",
            "publisher": "Lexaloffle",
            "genre": "Various / Utilities",
            "players": "1",
            "altemulator": "PICO-8 Splore (Standalone)"
          }
        }
      }
    },
    "bios": [
      {
        "filename": "pico8",
        "system": "pico8",
        "description": "PICO-8 executable",
        "required": "Required",
        "paths": "$bios_path/pico-8"
      },
      {
        "filename": "pico8.dat",
        "system": "pico8",
        "description": "PICO-8 system data file",
        "required": "Required",
        "paths": "$bios_path/pico-8"
      },
      {
        "filename": "pico8_dyn",
        "system": "pico8",
        "description": "Dynamic library for PICO-8",
        "required": "Required",
        "paths": "$bios_path/pico-8"
      }
    ]
  }
}
