{
  "pico-8": {
    "name": "PICO-8",
    "core_framework_compatibility": "1",
    "component_version": "1.0.0",
    "url_rdwiki": "https://retrodeck.readthedocs.io/en/latest/wiki_emulator_guides/pico-8/pico-8-guide/",
    "url_webpage": "https://www.lexaloffle.com/pico-8.php",
    "url_donation_purchase": "",
    "description": "PICO-8 is a fantasy console for playing tiny, retro-style games.",
    "system_friendly_name": "PICO-8 Fantasy Console",
    "component_type": "Emulator",
    "system": "pico8",
    "es_de_config": {
      "es_find_rules": {
        "emulators": [
          {
            "name": "PICO-8",
            "description": "PICO-8 Fantasy Console (game engine)",
            "rules": [
              {
                "type": "staticpath",
                "entries": [
                  "%COMPONENT_PATH%/component_launcher.sh"
                ]
              }
            ]
          }
        ]
      },
      "es_systems": [
        {
          "name": "pico8",
          "fullname": "PICO-8 Fantasy Console",
          "path": "%ROMPATH%/pico8",
          "extension": ".p8 .png",
          "commands": [
            {
              "label": "PICO-8 (Standalone)",
              "command": "%EMULATOR_PICO-8% -root_path %GAMEDIR% -run %ROM%",
              "priority": 10
            },
            {
              "label": "PICO-8 Splore (Standalone)",
              "command": "%EMULATOR_PICO-8% -root_path %GAMEDIR% -splore",
              "priority": 20
            }
          ],
          "platform": "pico8",
          "theme": "pico8"
        }
      ]
    },
    "bios": [
      {
        "filename": "pico8",
        "system": "pico8",
        "description": "PICO-8 executable",
        "required": "Required",
        "paths": "$bios_path/pico-8"
      },
      {
        "filename": "pico8.dat",
        "system": "pico8",
        "description": "PICO-8 system data file",
        "required": "Required",
        "paths": "$bios_path/pico-8"
      },
      {
        "filename": "pico8_dyn",
        "system": "pico8",
        "description": "Dynamic library for PICO-8",
        "required": "Required",
        "paths": "$bios_path/pico-8"
      }
    ]
  }
}
