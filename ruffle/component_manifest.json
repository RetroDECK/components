{
  "ruffle": {
    "name": "Ruffle",
    "core_framework_compatibility": "1",
    "component_version": "1.0.0",
    "capabilities": ["reset","open"],
    "url_rdwiki": "https://retrodeck.readthedocs.io/en/latest/wiki_emulator_guides/ruffle/ruffle-guide/",
    "url_webpage": "https://ruffle.rs/",
    "url_donation_purchase": "https://opencollective.com/ruffle",
    "url_source": "https://github.com/ruffle-rs/ruffle/",
    "description": "Ruffle is a Flash Player (flash) emulator.",
    "component_type": "Emulator",
    "system_friendly_name": "Flash Player Emulator",
    "system": "flash",
    "es_de_config": {
      "es_find_rules": {
        "emulators": [
          {
            "name": "RUFFLE",
            "description": "Adobe Flash player Ruffle",
            "rules": [
              {
                "type": "staticpath",
                "entries": [
                  "%COMPONENT_PATH%/component_launcher.sh"
                ]
              }
            ]
          }
        ]
      },
      "es_systems": [
        {
          "name": "flash",
          "fullname": "Adobe Flash",
          "path": "%ROMPATH%/flash",
          "extension": ".ruf .swf",
          "commands": [
            {
              "label": "Ruffle (Standalone)",
              "command": "%EMULATOR_RUFFLE% --fullscreen %ROM%",
              "priority": 10
            }
          ],
          "platform": "flash",
          "theme": "flash"
        }
      ]
    }
  }
}
