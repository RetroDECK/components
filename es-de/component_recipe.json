{
  "es-de": [
    {
      "source_url": "https://github.com/RetroDECK/ES-DE/releases/download/{VERSION}/ES-DE_x64_RetroDECK.AppImage",
      "source_type": "github_release",
      "version": "$ES_DE_DESIRED_VERSION",
      "extraction_type": "appimage",
      "assets": [
        {
          "type": "dir",
          "source": "usr/bin",
          "dest": "bin"
        },
        {
          "type": "dir",
          "source": "usr/share",
          "dest": "share"
        },
        {
          "type": "cleanup-dir",
          "source": "$COMPONENT_ARTIFACT_ROOT/share/es-de/resources/systems/linux"
        },
        {
          "type": "symlink",
          "source": "$COMPONENT_ARTIFACT_ROOT/share/es-de/resources/systems/linux",
          "dest": "/var/config/ES-DE/systems"
        },
        {
          "type": "dir",
          "source": "usr/lib",
          "dest": "lib"
        },
        {
          "type": "create",
          "dest": "component_version",
          "contents": "$SOURCE_VERSION"
        },
        {
          "type": "dir",
          "source": "$REPO_ROOT/$COMPONENT_NAME/rd_assets/rd_config",
          "dest": "rd_config"
        },
        {
          "type": "dir",
          "source": "$REPO_ROOT/$COMPONENT_NAME/rd_assets/rd_tools",
          "dest": "rd_tools"
        },
        {
          "type": "dir",
          "source": "$REPO_ROOT/$COMPONENT_NAME/rd_assets/helper_files",
          "dest": "$COMPONENT_ARTIFACT_ROOT/helper_files"
        },
        {
          "type": "dir",
          "source": "$REPO_ROOT/$COMPONENT_NAME/rd_assets/res",
          "dest": "$COMPONENT_ARTIFACT_ROOT/res"
        },
        {
          "type": "file",
          "source": "$REPO_ROOT/$COMPONENT_NAME/component_functions.sh",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        },
        {
          "type": "file",
          "source": "$REPO_ROOT/$COMPONENT_NAME/component_launcher.sh",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        },
        {
          "type": "file",
          "source": "$REPO_ROOT/$COMPONENT_NAME/component_manifest.json",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        },
        {
          "type": "file",
          "source": "$REPO_ROOT/$COMPONENT_NAME/component_recipe.json",
          "dest": "$COMPONENT_ARTIFACT_ROOT"
        }
      ]
    },
    {
      "source_url": "https://github.com/RetroDECK/RetroDECK-theme/archive/refs/heads/main.zip",
      "source_type": "http",
      "extraction_type": "archive",
      "assets": [
        {
          "type": "dir",
          "source": "$EXTRACTED_PATH",
          "dest": "$COMPONENT_ARTIFACT_ROOT/share/es-de/themes"
        }
      ]
    },
    {
      "source_url": "https://gitlab.com/es-de/emulationstation-de/-/raw/master/resources/systems/linux/es_find_rules.xml",
      "source_type": "http",
      "extraction_type": "local",
      "assets": [
        {
          "type": "file-rename",
          "source": "$EXTRACTED_PATH",
          "dest": "rd_config/es_find_rules_official.xml"
        }
      ]
    },
    {
      "source_url": "https://gitlab.com/es-de/emulationstation-de/-/raw/master/resources/systems/linux/es_systems.xml",
      "source_type": "http",
      "extraction_type": "local",
      "assets": [
        {
          "type": "file-rename",
          "source": "$EXTRACTED_PATH",
          "dest": "rd_config/es_systems_official.xml"
        }
      ]
    }
  ]
}
