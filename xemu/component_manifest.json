{
  "xemu": {
    "name": "xemu",
    "core_framework_compatibility": "1",
    "component_version": "1.0.0",
    "capabilities": ["reset","open"],
    "description": "xemu is a Microsoft Xbox (xbox) emulator.",
    "url_rdwiki": "https://retrodeck.readthedocs.io/en/latest/wiki_emulator_guides/xemu/xemu-guide/",
    "url_webpage": "https://xemu.app/",
    "url_donation_purchase": "https://www.patreon.com/mborgerson",
    "url_source": "https://github.com/xemu-project/xemu",
    "component_type": "Emulator",
    "system_friendly_name": "Xbox",
    "system": "xbox",
    "es_de_config": {
      "es_find_rules": {
        "emulators": [
          {
            "name": "XEMU",
            "description": "Microsoft Xbox emulator xemu",
            "rules": [
              {
                "type": "staticpath",
                "entries": [
                  "%COMPONENT_PATH%/component_launcher.sh"
                ]
              }
            ]
          }
        ]
      },
      "es_systems": [
        {
          "name": "consolearcade",
          "fullname": "Console Arcade Systems",
          "path": "%ROMPATH%/consolearcade",
          "extension": ".7z .arcadedef .desktop .iso .ps3 .sh .xbe .zip",
          "commands": [
            {
              "label": "xemu (Standalone)",
              "command": "%INJECT%=%BASENAME%.esprefix %EMULATOR_XEMU% -dvd_path %ROM%",
              "priority": 70
            }
          ],
          "platform": "arcade",
          "theme": "consolearcade"
        },
        {
          "name": "xbox",
          "fullname": "Microsoft Xbox",
          "path": "%ROMPATH%/xbox",
          "extension": ".iso",
          "commands": [
            {
              "label": "xemu (Standalone)",
              "command": "%INJECT%=%BASENAME%.esprefix %EMULATOR_XEMU% -dvd_path %ROM%",
              "priority": 10
            }
          ],
          "platform": "xbox",
          "theme": "xbox"
        }
      ]
    },
    "compression": {
      "xiso": {
        "targets": [
          "xbox"
        ]
      }
    },
    "bios": [
      {
        "filename": "mcpx_1.0.bin",
        "md5": "d49c52a4102f6df7bcf8d0617ac475ed",
        "system": "xbox",
        "description": "Xbox BIOS"
      },
      {
        "filename": "Complex.bin",
        "system": "xbox",
        "description": "XBOX Complex BIOS"
      },
      {
        "filename": "Complex_4627v1.03.bin",
        "system": "xbox",
        "description": "XBOX Complex BIOS 1.03"
      },
      {
        "filename": "Complex_4627.bin",
        "system": "xbox",
        "description": "XBOX Complex BIOS 4627"
      }
    ]
  }
}
