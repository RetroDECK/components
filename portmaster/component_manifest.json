{
  "portmaster": {
    "description": "PortMaster a port manager that simplifies installing and updating ports.",
    "name": "PortMaster",
    "core_framework_compatibility": "1",
    "component_version": "1.0.0",
    "capabilities": ["reset","open"],
    "prepare_priority": {
      "startup": 90
    },
    "url_rdwiki": "https://retrodeck.readthedocs.io/en/latest/wiki_port_guides/portmaster/portmaster-guide/",
    "url_webpage": "https://portmaster.games/index.html",
    "url_donation_purchase": "https://opencollective.com/portmaster",
    "url_source": "https://github.com/PortsMaster/PortMaster-New",
    "system_friendly_name": "PortMaster",
    "component_type": "System",
    "system": "portmaster",
    "backup_data": {
      "core": [
        {"path": "$XDG_DATA_HOME/PortMaster"}
      ]
    },
    "component_options": {
      "portmaster_reload_esde": "true",
      "portmaster_show": "true"
    },
    "component_paths": {
      "portmaster_path": {
        "path": "$rd_home_path/PortMaster",
        "recommended_scope": "shared",
        "description": "PortMaster core directory"
      }
    },
    "configurator_menus": {
      "settings": [
        {
          "name": "PortMaster in ES-DE",
          "description": "Enable or disable: PortMaster entry in ES-DE.",
          "command": {
            "zenity": "configurator_portmaster_toggle_dialog"
          }
        }
      ]
    },
    "es_de_config": {
      "es_find_rules": {
        "emulators": [
          {
            "name": "PORTMASTER",
            "description": "PORTMASTER",
            "rules": [
              {
                "type": "staticpath",
                "entries": [
                  "%COMPONENT_PATH%/component_launcher.sh"
                ]
              }
            ]
          }
        ]
      },
      "es_systems": [
        {
          "name": "portmaster",
          "fullname": "PortMaster",
          "path": "%ROMPATH%/portmaster",
          "extension": ".sh",
          "commands": [
            {
              "label": "PortMaster",
              "command": "%ENABLESHORTCUTS% %EMULATOR_PORTMASTER% %ROM%",
              "priority": 10
            }
          ],
          "platform": "portmaster",
          "theme": "portmaster"
        }
      ]
    },
    "helper_files": [
      {
        "filename": "portmaster_guide.txt",
        "location": "$portmaster_path"
      }
    ]
  }
}
